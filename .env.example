# =============================================================================
# Auto-Healing AI DevOps Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values before running docker-compose

# --- AI Model Configuration ---
# Varje agent har 4 modellslots: primary + 3 fallbacks
# Lämna tomma tills du valt modeller

# Agent 1: Pipeline Monitor
PIPELINE_MONITOR_PRIMARY_MODEL=
PIPELINE_MONITOR_FALLBACK_1=
PIPELINE_MONITOR_FALLBACK_2=
PIPELINE_MONITOR_FALLBACK_3=

# Agent 2: Task Inspector
TASK_INSPECTOR_PRIMARY_MODEL=
TASK_INSPECTOR_FALLBACK_1=
TASK_INSPECTOR_FALLBACK_2=
TASK_INSPECTOR_FALLBACK_3=

# Agent 3: Log Analyst
LOG_ANALYST_PRIMARY_MODEL=
LOG_ANALYST_FALLBACK_1=
LOG_ANALYST_FALLBACK_2=
LOG_ANALYST_FALLBACK_3=

# Agent 4: Error Analyst
ERROR_ANALYST_PRIMARY_MODEL=
ERROR_ANALYST_FALLBACK_1=
ERROR_ANALYST_FALLBACK_2=
ERROR_ANALYST_FALLBACK_3=

# Agent 5: Code Repairer
CODE_REPAIRER_PRIMARY_MODEL=
CODE_REPAIRER_FALLBACK_1=
CODE_REPAIRER_FALLBACK_2=
CODE_REPAIRER_FALLBACK_3=

# Agent 6: Review & Notify
REVIEW_NOTIFY_PRIMARY_MODEL=
REVIEW_NOTIFY_FALLBACK_1=
REVIEW_NOTIFY_FALLBACK_2=
REVIEW_NOTIFY_FALLBACK_3=

# --- API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Jenkins ---
JENKINS_URL=http://localhost:8080
JENKINS_USER=
JENKINS_TOKEN=

# --- GitHub ---
GITHUB_TOKEN=

# --- Gerrit ---
GERRIT_URL=

# --- Notifications ---
TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# --- Service URLs (inter-service communication) ---
ORCHESTRATOR_URL=http://orchestrator-mcp:8085
LLM_URL=http://llm-mcp:8084
LOG_CLEANER_URL=http://log-cleaner-mcp:8083
KNOWLEDGE_GRAPH_URL=http://knowledge-graph-mcp:8086
NOTIFICATION_URL=http://notification-mcp:8087

# --- Token Budget ---
MAX_TOKENS_PER_HOUR=100000
MAX_TOKENS_PER_REQUEST=4096

# --- Scheduler ---
SCHEDULE_INTERVAL_MINUTES=5

# --- Logging ---
LOG_LEVEL=INFO

# --- Service identity (set per container in docker-compose) ---
SERVICE_NAME=
SERVICE_PORT=
